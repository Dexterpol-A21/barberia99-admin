---
import Layout from "../layouts/Layout.astro";
import ButtonCTA from "../components/ui/ButtonCTA.astro";
import Logo from "../components/Logo.astro";
---

<Layout title="Admin Panel | Barbería 99">
    <main class="min-h-screen bg-[#050301] text-bone flex flex-col justify-center items-center px-4 relative overflow-hidden">

        <div class="z-10 w-full max-w-sm bg-carbon/80 border border-white/10 p-8 rounded-sm backdrop-blur-md shadow-2xl">
            <div class="flex justify-center mb-8">
                <div class="scale-110">
                    <Logo />
                </div>
            </div>
            <div class="text-center mb-8 border-t border-white/10 pt-4">
                <span class="text-white text-xs tracking-[0.4em] font-bold uppercase block">Acceso Restringido</span>
                <p class="text-cement text-[10px] mt-1 uppercase">Dashboard Administrativo</p>
            </div>

            <form id="login-form" class="space-y-4" novalidate>
                <div>
                    <label for="email" class="block text-xs uppercase tracking-wider text-cement mb-2">Usuario / Email</label>
                    <input id="email" type="email" class="w-full bg-black/50 border border-white/10 rounded-sm p-3 text-white focus:border-amber focus:outline-none transition-colors" placeholder="admin@barberia99.com" />
                    <p id="email-error" class="hidden text-red-500 text-[11px] mt-1.5 ml-1"></p>
                </div>
                <div>
                    <label for="password" class="block text-xs uppercase tracking-wider text-cement mb-2">Contraseña</label>
                    <div class="relative">
                        <input id="password" type="password" class="w-full bg-black/50 border border-white/10 rounded-sm p-3 text-white focus:border-amber focus:outline-none transition-colors pr-10" placeholder="••••••••" />
                        <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 pr-3 flex items-center text-cement hover:text-white transition-colors" tabindex="-1">
                            <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg id="eye-off-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye-off hidden"><path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/><path d="m2 2 20 20"/></svg>
                        </button>
                    </div>
                    <p id="password-error" class="hidden text-red-500 text-[11px] mt-1.5 ml-1"></p>
                </div>

                <div id="error-message" class="hidden text-red-500 text-xs text-center border border-red-500/20 bg-red-500/10 p-2 rounded-sm mt-2">
                    Credenciales incorrectas
                </div>

                <div class="pt-4">
                    <ButtonCTA id="submit-btn" isSubmit={true} class="w-full h-12 text-sm rounded-sm">
                        Entrar al Sistema
                    </ButtonCTA>
                </div>
            </form>
        </div>
    </main>

    <script>
        import { supabase } from "../lib/supabase";

        const form = document.getElementById("login-form") as HTMLFormElement;
        const emailInput = document.getElementById("email") as HTMLInputElement;
        const passwordInput = document.getElementById("password") as HTMLInputElement;
        const emailErrorEl = document.getElementById("email-error");
        const passwordErrorEl = document.getElementById("password-error");
        const errorMessage = document.getElementById("error-message");
        const submitBtn = document.getElementById("submit-btn");
        const togglePasswordBtn = document.getElementById("toggle-password");
        const eyeIcon = document.getElementById("eye-icon");
        const eyeOffIcon = document.getElementById("eye-off-icon");

        // Toggle Mostrar/Ocultar Contraseña
        togglePasswordBtn?.addEventListener("click", () => {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);
            
            if (type === "text") {
                eyeIcon?.classList.add("hidden");
                eyeOffIcon?.classList.remove("hidden");
            } else {
                eyeIcon?.classList.remove("hidden");
                eyeOffIcon?.classList.add("hidden");
            }
        });

        // Autocompletar con los datos de prueba de manera visual para ahorrarte tiempo de escritura (Opcional)
        // if (emailInput && passwordInput) {
        //     emailInput.value = "";
        //     passwordInput.value = "";
        // }

        const resetErrors = () => {
            [emailInput, passwordInput].forEach(el => {
                if(el) {
                    el.classList.remove("border-red-500", "focus:border-red-500");
                    el.classList.add("border-white/10", "focus:border-amber");
                }
            });
            if (emailErrorEl) emailErrorEl.classList.add("hidden");
            if (passwordErrorEl) passwordErrorEl.classList.add("hidden");
            if (errorMessage) errorMessage.classList.add("hidden");
        };

        const setFieldError = (input: HTMLInputElement, errorEl: HTMLElement | null, msg: string) => {
            input.classList.remove("border-white/10", "focus:border-amber");
            input.classList.add("border-red-500", "focus:border-red-500");
            if (errorEl) {
                errorEl.textContent = msg;
                errorEl.classList.remove("hidden");
            }
        };

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            resetErrors();
            
            let hasError = false;
            
            if (!emailInput.value.trim()) {
                setFieldError(emailInput, emailErrorEl, "El correo electrónico es obligatorio.");
                hasError = true;
            } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
                setFieldError(emailInput, emailErrorEl, "Por favor, ingresa un correo válido.");
                hasError = true;
            }

            if (!passwordInput.value.trim()) {
                setFieldError(passwordInput, passwordErrorEl, "La contraseña es obligatoria.");
                hasError = true;
            }

            if (hasError) return;

            // Efecto visual de loading
            if (submitBtn) submitBtn.style.opacity = "0.7";

            const { data, error } = await supabase.auth.signInWithPassword({
                email: emailInput.value,
                password: passwordInput.value,
            });

            if (error) {
                console.error("Error validando:", error);
                if (errorMessage) {
                    errorMessage.textContent = error.message.includes("Invalid login") 
                        ? "Correo o contraseña incorrectos" 
                        : "Error al intentar iniciar sesión. Revisa tu consola.";
                    errorMessage.classList.remove("hidden");
                }
                setFieldError(emailInput, null, "");
                setFieldError(passwordInput, null, "");
                if (submitBtn) submitBtn.style.opacity = "1";
            } else {
                // Login exitoso, check role en la base de datos real
                const { data: { user } } = await supabase.auth.getUser();
                
                if (user) {
                    // Buscar perfil para verificar rol
                    const { data: profile } = await supabase
                        .from('profiles')
                        .select('role')
                        .eq('id', user.id)
                        .single();

                    const userRole = profile?.role || user.user_metadata?.role || 'client';

                    if (userRole === 'client') {
                        // Bloquear acceso a clientes
                        await supabase.auth.signOut();
                        if (errorMessage) {
                            errorMessage.innerHTML = "Acceso denegado. Plataforma exclusiva para personal. <br><a href='https://barberia99.com/inicio' class='text-amber underline mt-2 inline-block hover:text-white transition-colors z-50 relative pointer-events-auto'>Ir al portal de clientes</a>";
                            errorMessage.classList.remove("hidden");
                            
                            // Asegurar que el padre permita clics
                            errorMessage.style.pointerEvents = "auto";
                        }
                        if (submitBtn) submitBtn.style.opacity = "1";
                        return;
                    }

                    // Rutas por rol
                    if (userRole === 'barber') {
                        window.location.href = "/barbero";
                    } else {
                        window.location.href = "/dashboard"; // owner, admin
                    }
                }
            }
        });
    </script>
</Layout>
