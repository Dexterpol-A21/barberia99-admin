---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import ButtonCTA from "../../../components/ui/ButtonCTA.astro";
import { Search, Filter, X, Mail, User, Percent, Scissors, CheckCircle, Trash2, Edit2, Clock } from "lucide-react";
---

<DashboardLayout title="Gestión de Barberos | Barbería 99">
    <div class="w-full mx-auto space-y-6 relative">
        <h1 class="hidden">Gestión de Barberos</h1>

        <!-- Toolbar de Acciones -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div class="relative w-full max-w-sm flex items-center">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-cement" size={16} />
                <input type="text" placeholder="Buscar por nombre o alias..." class="w-full bg-carbon/60 border border-white/10 rounded-sm pl-9 pr-4 h-10 text-sm text-white placeholder-cement focus:border-amber focus:outline-none transition-colors" />
            </div>

            <div class="flex items-center gap-3 w-full sm:w-auto">
                <button class="bg-carbon/60 border border-white/10 text-cement hover:text-white h-10 px-3 rounded-sm transition-colors flex items-center gap-2">
                    <Filter size={16} /> <span class="hidden sm:inline text-sm">Filtrar</span>
                </button>
                <ButtonCTA id="btn-open-modal" class="!h-10 !px-4 !text-sm !w-auto !min-w-0 !font-semibold cursor-pointer">
                    + Nuevo Barbero
                </ButtonCTA>
            </div>
        </div>

        <!-- Contenedor Principal (Tabla) -->
        <div class="bg-carbon/60 border border-white/5 rounded-sm backdrop-blur-sm p-0 overflow-hidden">
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse" id="barbers-table">
                    <thead>
                        <tr class="border-b border-white/5 bg-white/5">
                            <th class="p-4 text-xs font-semibold text-cement tracking-wider uppercase">Barbero</th>
                            <th class="p-4 text-xs font-semibold text-cement tracking-wider uppercase">Nombre Completo</th>
                            <th class="p-4 text-xs font-semibold text-cement tracking-wider uppercase">Horario</th>
                            <th class="p-4 text-xs font-semibold text-cement tracking-wider uppercase">Comisión</th>
                            <th class="p-4 text-xs font-semibold text-cement tracking-wider uppercase">Estado</th>
                            <th class="p-4 text-xs font-semibold text-cement tracking-wider uppercase text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5" id="barbers-tbody">
                        <tr>
                            <td colspan="6" class="p-6 text-center text-cement text-sm font-mono">
                                [ Cargando barberos... ]
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Modal Invite Barber -->
        <div id="modal-invite" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
            <div class="bg-[#0a0806] border border-white/10 rounded-sm w-full max-w-md p-6 transform scale-95 transition-transform duration-300 relative" id="modal-content">
                <button id="btn-close-modal" class="absolute top-4 right-4 text-cement hover:text-white transition-colors cursor-pointer">
                    <X size={20} />
                </button>

                <div class="mb-6">
                    <h2 class="font-display text-xl text-white" id="modal-title">Vincular / Editar Barbero</h2>
                    <p class="text-xs text-cement mt-1" id="modal-subtitle">Busca un cliente registrado por su correo y conéctalo al panel.</p>
                </div>

                <div id="modal-notification" class="hidden mb-4 p-3 rounded-sm text-sm font-medium flex items-center gap-2"></div>
                
                <form id="invite-barber-form" class="space-y-4">
                    <input type="hidden" id="input-barber-id" />

                    <div>
                        <label class="block text-xs uppercase tracking-widest text-cement font-bold mb-2">Correo Electrónico a Vincular</label>
                        <div class="relative flex items-center">
                            <Mail className="absolute left-3 top-1/2 -translate-y-1/2 text-cement" size={16} />
                            <input type="email" id="input-email" required placeholder="correo@ejemplo.com" class="w-full bg-carbon/60 border border-white/10 rounded-sm pl-9 pr-4 h-11 text-sm text-white placeholder-cement focus:border-amber focus:outline-none transition-colors" />
                        </div>
                        <p class="text-[10px] text-amber mt-1 hidden" id="edit-notice-email">Si dejas este correo así, se intentará actualizar el perfil asociado si existe.</p>
                    </div>

                    <div>
                        <label class="block text-xs uppercase tracking-widest text-cement font-bold mb-2">Alias / Apodo</label>
                        <div class="relative flex items-center">
                            <User className="absolute left-3 top-1/2 -translate-y-1/2 text-cement" size={16} />
                            <input type="text" id="input-alias" required maxlength="15" placeholder="Ej. Master Hugo" class="w-full bg-carbon/60 border border-white/10 rounded-sm pl-9 pr-4 h-11 text-sm text-white placeholder-cement focus:border-amber focus:outline-none transition-colors" />
                        </div>
                        <p class="text-[10px] text-cement/60 mt-1 text-right">Máximo 15 caracteres</p>
                    </div>

                    <div>
                        <label class="block text-xs uppercase tracking-widest text-cement font-bold mb-2">Especialidad</label>
                        <div class="relative flex items-center">
                            <Scissors className="absolute left-3 top-1/2 -translate-y-1/2 text-cement" size={16} />
                            <input type="text" id="input-specialty" required maxlength="20" placeholder="Ej. Fades, Maestro..." class="w-full bg-carbon/60 border border-white/10 rounded-sm pl-9 pr-4 h-11 text-sm text-white placeholder-cement focus:border-amber focus:outline-none transition-colors" />
                        </div>
                        <p class="text-[10px] text-cement/60 mt-1 text-right">Máximo 20 caracteres</p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs uppercase tracking-widest text-cement font-bold mb-2">Comisión (%)</label>
                            <div class="relative flex items-center">
                                <Percent className="absolute left-3 top-1/2 -translate-y-1/2 text-cement" size={16} />
                                <input type="number" id="input-commission" required min="0" max="100" value="50" class="w-full bg-carbon/60 border border-white/10 rounded-sm pl-9 pr-4 h-11 text-sm text-white placeholder-cement focus:border-amber focus:outline-none transition-colors" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs uppercase tracking-widest text-cement font-bold mb-2" title="Garantía de cortes base">Cuota Silla</label>
                            <div class="relative flex items-center">
                                <Scissors className="absolute left-3 top-1/2 -translate-y-1/2 text-cement" size={16} />
                                <input type="number" id="input-quota" required min="0" value="10" class="w-full bg-carbon/60 border border-white/10 rounded-sm pl-9 pr-4 h-11 text-sm text-white placeholder-cement focus:border-amber focus:outline-none transition-colors" />
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-white/5 pt-4 mt-2">
                        <h3 class="text-white text-sm font-bold mb-3 flex items-center gap-2"><Clock size={16} className="text-amber"/> Horario Base</h3>
                        <div class="grid grid-cols-2 gap-4 mb-3">
                            <div>
                                <label class="block text-[10px] uppercase text-cement font-bold mb-1">Entrada</label>
                                <select id="input-start-time" class="w-full bg-carbon/60 border border-white/10 rounded-sm px-3 h-10 text-sm text-white focus:border-amber outline-none cursor-pointer appearance-none">
                                    <option value="08:00">08:00 a. m.</option>
                                    <option value="08:30">08:30 a. m.</option>
                                    <option value="09:00">09:00 a. m.</option>
                                    <option value="09:30">09:30 a. m.</option>
                                    <option value="10:00" selected>10:00 a. m.</option>
                                    <option value="10:30">10:30 a. m.</option>
                                    <option value="11:00">11:00 a. m.</option>
                                    <option value="11:30">11:30 a. m.</option>
                                    <option value="12:00">12:00 p. m.</option>
                                    <option value="12:30">12:30 p. m.</option>
                                    <option value="13:00">01:00 p. m.</option>
                                    <option value="13:30">01:30 p. m.</option>
                                    <option value="14:00">02:00 p. m.</option>
                                    <option value="14:30">02:30 p. m.</option>
                                    <option value="15:00">03:00 p. m.</option>
                                    <option value="15:30">03:30 p. m.</option>
                                    <option value="16:00">04:00 p. m.</option>
                                    <option value="16:30">04:30 p. m.</option>
                                    <option value="17:00">05:00 p. m.</option>
                                    <option value="17:30">05:30 p. m.</option>
                                    <option value="18:00">06:00 p. m.</option>
                                    <option value="18:30">06:30 p. m.</option>
                                    <option value="19:00">07:00 p. m.</option>
                                    <option value="19:30">07:30 p. m.</option>
                                    <option value="20:00">08:00 p. m.</option>
                                    <option value="20:30">08:30 p. m.</option>
                                    <option value="21:00">09:00 p. m.</option>
                                    <option value="21:30">09:30 p. m.</option>
                                    <option value="22:00">10:00 p. m.</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] uppercase text-cement font-bold mb-1">Salida</label>
                                <select id="input-end-time" class="w-full bg-carbon/60 border border-white/10 rounded-sm px-3 h-10 text-sm text-white focus:border-amber outline-none cursor-pointer appearance-none">
                                    <option value="08:00">08:00 a. m.</option>
                                    <option value="08:30">08:30 a. m.</option>
                                    <option value="09:00">09:00 a. m.</option>
                                    <option value="09:30">09:30 a. m.</option>
                                    <option value="10:00">10:00 a. m.</option>
                                    <option value="10:30">10:30 a. m.</option>
                                    <option value="11:00">11:00 a. m.</option>
                                    <option value="11:30">11:30 a. m.</option>
                                    <option value="12:00">12:00 p. m.</option>
                                    <option value="12:30">12:30 p. m.</option>
                                    <option value="13:00">01:00 p. m.</option>
                                    <option value="13:30">01:30 p. m.</option>
                                    <option value="14:00">02:00 p. m.</option>
                                    <option value="14:30">02:30 p. m.</option>
                                    <option value="15:00">03:00 p. m.</option>
                                    <option value="15:30">03:30 p. m.</option>
                                    <option value="16:00">04:00 p. m.</option>
                                    <option value="16:30">04:30 p. m.</option>
                                    <option value="17:00">05:00 p. m.</option>
                                    <option value="17:30">05:30 p. m.</option>
                                    <option value="18:00">06:00 p. m.</option>
                                    <option value="18:30">06:30 p. m.</option>
                                    <option value="19:00">07:00 p. m.</option>
                                    <option value="19:30">07:30 p. m.</option>
                                    <option value="20:00" selected>08:00 p. m.</option>
                                    <option value="20:30">08:30 p. m.</option>
                                    <option value="21:00">09:00 p. m.</option>
                                    <option value="21:30">09:30 p. m.</option>
                                    <option value="22:00">10:00 p. m.</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] uppercase text-cement font-bold mb-3">Días Laborales</label>
                            <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm" id="days-container">
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="1" checked class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Lu</label>
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="2" checked class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Ma</label>
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="3" checked class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Mi</label>
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="4" checked class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Ju</label>
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="5" checked class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Vi</label>
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="6" checked class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Sa</label>
                                <label class="flex items-center gap-1.5 cursor-pointer text-white/80 hover:text-white"><input type="checkbox" value="0" class="accent-amber w-4 h-4 cursor-pointer day-checkbox"> Do</label>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 mt-4 hidden" id="div-active">
                        <input type="checkbox" id="input-active" checked class="accent-amber w-4 h-4 cursor-pointer" />
                        <label class="text-sm text-cement cursor-pointer" for="input-active">Barbero Activo</label>
                    </div>

                    <div class="pt-4 flex justify-end gap-3 border-t border-white/5 mt-6">
                        <button type="button" id="btn-cancel-modal" class="px-4 py-2 text-sm text-cement font-medium hover:text-white transition-colors cursor-pointer">
                            Cancelar
                        </button>
                        <ButtonCTA isSubmit={true} id="btn-submit-modal" class="!h-10 !px-6 !text-sm !w-auto !min-w-0 !font-semibold">
                            Guardar Barbero
                        </ButtonCTA>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        import { supabase } from '../../../lib/supabase';

        const btnOpen = document.getElementById('btn-open-modal');
        const btnClose = document.getElementById('btn-close-modal');
        const btnCancel = document.getElementById('btn-cancel-modal');
        const modal = document.getElementById('modal-invite');
        const modalContent = document.getElementById('modal-content');
        const notif = document.getElementById('modal-notification');

        function openModal() {
            if(!modal || !modalContent) return;
            modal.classList.remove('opacity-0', 'pointer-events-none');
            modalContent.classList.remove('scale-95');
            modalContent.classList.add('scale-100');
        }

        function closeModal() {
            if(!modal || !modalContent) return;
            modal.classList.add('opacity-0', 'pointer-events-none');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            hideNotif();
        }

        function showNotif(message: string, isError = false) {
            if (!notif) return;
            notif.innerHTML = message;
            notif.classList.remove('hidden');
            
            if(isError) {
                notif.className = 'mb-4 p-3 rounded-sm text-sm font-medium flex items-center gap-2 bg-red-500/20 text-red-500 border border-red-500/50';
            } else {
                notif.className = 'mb-4 p-3 rounded-sm text-sm font-medium flex items-center gap-2 bg-green-500/20 text-green-400 border border-green-500/50';
            }
        }

        function hideNotif() {
            if (!notif) return;
            notif.classList.add('hidden');
        }

        
        const inputId = document.getElementById('input-barber-id') as HTMLInputElement;
        const inputEmail = document.getElementById('input-email') as HTMLInputElement;
        const inputAlias = document.getElementById('input-alias') as HTMLInputElement;
        const inputSpecialty = document.getElementById('input-specialty') as HTMLInputElement;
        const inputCommission = document.getElementById('input-commission') as HTMLInputElement;
        const inputQuota = document.getElementById('input-quota') as HTMLInputElement;
        const inputActive = document.getElementById('input-active') as HTMLInputElement;
        const inputStartTime = document.getElementById('input-start-time') as HTMLInputElement;
        const inputEndTime = document.getElementById('input-end-time') as HTMLInputElement;
        const form = document.getElementById('invite-barber-form') as HTMLFormElement;
        const btnSubmit = form?.querySelector('button[type="submit"]');

        const divActive = document.getElementById('div-active');
        const noticeEmail = document.getElementById('edit-notice-email');
        const modalTitle = document.getElementById('modal-title');
        const modalSubtitle = document.getElementById('modal-subtitle');
        const barbersTbody = document.getElementById('barbers-tbody');

        async function loadBarbers() {
            try {
                // Hacer el componente cliente para Supabase local
                const { data: barberos, error } = await supabase
                    .from('barbers')
                    .select(`
                        id,
                        nickname,
                        specialty,
                        commission_rate,
                        base_quota_cuts,
                        is_active,
                        schedule,
                        profile_id,
                        profiles (
                            first_name,
                            phone
                        )
                    `)
                    .order('created_at', { ascending: false });

                if (error) throw error;

                if (!barberos || barberos.length === 0) {
                    if(barbersTbody) barbersTbody.innerHTML = `<tr><td colspan="6" class="p-6 text-center text-cement text-sm font-mono">[ Lista de Barberos aparecerá aquí al agregarlos ]</td></tr>`;
                    return;
                }

                if(barbersTbody) {
                    barbersTbody.innerHTML = barberos.map(barbero => {
                        const sched = barbero.schedule || { startTime: '10:00', endTime: '20:00', workDays: ['1','2','3','4','5','6'] };
                        const daysMap: Record<string,string> = { '1':'Lu', '2':'Ma', '3':'Mi', '4':'Ju', '5':'Vi', '6':'Sa', '0':'Do' };
                        let daysStr = (sched.workDays || []).map((d: any) => daysMap[d.toString()]).join(', ');
                        if(!daysStr) daysStr = 'Sin asignar';

                        return `
                        <tr class="hover:bg-white/[0.02] transition-colors group">
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-amber/10 border border-amber/20 flex items-center justify-center text-amber font-bold font-display uppercase">
                                        ${barbero.nickname ? barbero.nickname.substring(0, 1) : 'B'}
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-white">${barbero.nickname}</p>
                                        <p class="text-[10px] text-amber">${barbero.specialty || 'Barbero'}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="p-4 text-sm text-cement">
                                ${barbero.profiles ? `${barbero.profiles.first_name || 'Sin nombre'}`.trim() : 'Sin enlazar'}
                                ${barbero.profiles?.phone ? `<div class="text-[10px] text-cement/70">${barbero.profiles.phone}</div>` : ''}
                            </td>
                            <td class="p-4">
                                <div class="text-[10px] text-cement/70 font-medium mb-1">${daysStr}</div>
                                <div class="flex items-center gap-1.5 text-white text-xs">
                                    ${(sched.startTime.startsWith('0') || sched.startTime.startsWith('10') || sched.startTime.startsWith('11')) ? sched.startTime + ' am' : (parseInt(sched.startTime.split(':')[0]) > 12 ? (parseInt(sched.startTime.split(':')[0])-12).toString().padStart(2, '0') : parseInt(sched.startTime.split(':')[0]).toString().padStart(2, '0')) + ':' + sched.startTime.split(':')[1] + ' pm'} - ${(sched.endTime.startsWith('0') || sched.endTime.startsWith('10') || sched.endTime.startsWith('11')) ? sched.endTime + ' am' : (parseInt(sched.endTime.split(':')[0]) > 12 ? (parseInt(sched.endTime.split(':')[0])-12).toString().padStart(2, '0') : parseInt(sched.endTime.split(':')[0]).toString().padStart(2, '0')) + ':' + sched.endTime.split(':')[1] + ' pm'}
                                </div>
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-medium bg-white/10 text-white uppercase tracking-widest">
                                    ${barbero.commission_rate}%
                                </span>
                                <div class="text-[10px] text-cement/70 mt-1">Cuota: ${barbero.base_quota_cuts} cortes</div>
                            </td>
                            <td class="p-4">
                                ${barbero.is_active ? `
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-sm text-xs font-medium text-green-400">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Activo
                                    </span>
                                ` : `
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-sm text-xs font-medium text-red-400">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Inactivo
                                    </span>
                                `}
                            </td>
                            <td class="p-4 text-right flex justify-end gap-2">
                                <button class="btn-edit-barbero text-cement hover:text-amber transition-colors cursor-pointer p-2" title="Editar Horario y Barbero" data-barber='${JSON.stringify(barbero).replace(/'/g, "&#39;")}'>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                                </button>
                                <button class="btn-delete-barbero text-cement hover:text-red-400 transition-colors cursor-pointer p-2" title="Eliminar/Desactivar" data-id="${barbero.id}" data-profile-id="${barbero.profile_id}" data-name="${barbero.nickname}">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                </button>
                            </td>
                        </tr>
                        `;
                    }).join('');
                }
            } catch (err) {
                console.error("Error cargando barberos:", err);
            }
        }

        // Cargar al inicio
        loadBarbers();

        btnOpen?.addEventListener('click', () => {
            if(form) form.reset();
            if(inputId) inputId.value = '';
            if(inputCommission) inputCommission.value = '50';
            if(inputQuota) inputQuota.value = '10';
            if(modalTitle) modalTitle.innerText = 'Vincular Barbero';
            if(modalSubtitle) modalSubtitle.innerText = 'Buscaremos un cliente registrado y le daremos el rol de barbero.';
            if(divActive) divActive.classList.add('hidden');
            if(noticeEmail) noticeEmail.classList.add('hidden');
            if(btnSubmit) btnSubmit.innerHTML = 'Vincular y Guardar';
            if(inputEmail) {
                inputEmail.required = true;
                inputEmail.disabled = false;
                inputEmail.classList.remove('opacity-50', 'cursor-not-allowed');
                inputEmail.value = '';
            }
            openModal();
        });

        // Event delegation para botones eliminar (trash)
        document.addEventListener('click', async (e) => {
            const dlBtn = (e.target as Element).closest('.btn-delete-barbero') as HTMLElement;
            if (dlBtn) {
                const id = dlBtn.getAttribute('data-id');
                const profileId = dlBtn.getAttribute('data-profile-id');
                const name = dlBtn.getAttribute('data-name');
                
                if (confirm(`¿Estás seguro de que deseas eliminar definitivamente al barbero "${name}"?\nEsto le quitará el acceso al sistema y dejará de ser barbero.`)) {
                    try {
                        // 1. Quitar rol de barber en profiles
                        if (profileId) {
                            const { error: roleErr } = await supabase.from('profiles').update({ role: 'client' }).eq('id', profileId);
                            if (roleErr) console.warn("No se pudo quitar el rol. Omitiendo...", roleErr);
                        }
                        
                        // 2. Eliminar registro de barbers
                        const { error: delErr } = await supabase.from('barbers').delete().eq('id', id);
                        if (delErr) throw delErr;
                        
                        alert('Barbero eliminado correctamente.');
                        loadBarbers(); // Recargar la tabla
                    } catch (err) {
                        console.error('Error eliminando barbero:', err);
                        alert('Hubo un error al intentar eliminar el barbero.');
                    }
                }
            }
        });

        // Event delegation para botones editar
        document.addEventListener('click', (e) => {
            const target = (e.target as Element).closest('.btn-edit-barbero') as HTMLElement;
            if (!target) return;
            
            const dataRaw = target.dataset.barber || '{}';
            const data = JSON.parse(dataRaw);
            
            if(form) form.reset();
            
            if(inputId) inputId.value = data.id || '';
            
            if(inputEmail) {
                if (data.profiles?.email) {
                    inputEmail.value = data.profiles.email;
                } else if (data.profiles?.first_name) {
                    inputEmail.value = 'Enlazado (' + data.profiles.first_name + ')';
                }
                inputEmail.required = false;
                inputEmail.disabled = true;
                inputEmail.classList.add('opacity-50', 'cursor-not-allowed');
            }
            
            if(inputAlias) inputAlias.value = data.nickname || '';
            if(inputSpecialty) inputSpecialty.value = data.specialty || '';
            if(inputCommission) inputCommission.value = data.commission_rate || '50';
            if(inputQuota) inputQuota.value = data.base_quota_cuts || '10';
            if(inputActive) inputActive.checked = data.is_active !== false;

            // Load schedule
            if(data.schedule) {
                if(inputStartTime) inputStartTime.value = data.schedule.startTime || '10:00';
                if(inputEndTime) inputEndTime.value = data.schedule.endTime || '20:00';
                const days = data.schedule.workDays || [];
                document.querySelectorAll('.day-checkbox').forEach((cb: any) => {
                    cb.checked = days.includes(cb.value) || days.includes(parseInt(cb.value));
                });
            }

            if(modalTitle) modalTitle.innerText = 'Editar Barbero y Horario';
            if(modalSubtitle) modalSubtitle.innerText = 'Modifica comisiones, su horario base de trabajo o su estado activo.';
            if(divActive) divActive.classList.remove('hidden');
            if(noticeEmail) noticeEmail.classList.remove('hidden');
            if(btnSubmit) btnSubmit.innerHTML = 'Guardar Cambios';

            openModal();
        });

        btnClose?.addEventListener('click', closeModal);
        btnCancel?.addEventListener('click', closeModal);

        modal?.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideNotif();
            
            if(!btnSubmit) return;
            const originalText = btnSubmit.innerHTML;
            btnSubmit.innerHTML = 'Procesando...';
            btnSubmit.setAttribute('disabled', 'true');

            try {
                const id = inputId?.value;
                const email = inputEmail?.value;
                const nickname = inputAlias?.value || (email ? email.split('@')[0] : '');
                const specialty = inputSpecialty?.value || 'Barbero';
                const commission_rate = parseFloat(inputCommission?.value || "50");
                const base_quota_cuts = parseInt(inputQuota?.value || "10");
                const is_active = inputActive ? inputActive.checked : true;

                // Build schedule object
                const workDays: number[] = [];
                document.querySelectorAll('.day-checkbox:checked').forEach((cb: any) => {
                    workDays.push(parseInt(cb.value));
                });
                
                const schedule = {
                    startTime: inputStartTime?.value || "10:00",
                    endTime: inputEndTime?.value || "20:00",
                    workDays: workDays
                };

                // Validación de horas cruzadas
                if (schedule.startTime >= schedule.endTime) {
                    showNotif("La hora de salida debe ser después de la hora de entrada.", true);
                    btnSubmit.innerHTML = originalText;
                    btnSubmit.removeAttribute('disabled');
                    return;
                }

                if (id) {
                    // Update: El barbero ya existe
                    const { error } = await supabase.from('barbers').update({
                        nickname, specialty, commission_rate, base_quota_cuts, is_active, schedule
                    }).eq('id', id);
                    
                    if (error) throw error;
                    showNotif('¡Barbero actualizado correctamente!');
                } else {
                    // Insert: Vincular Barbero existente
                    // 1. Buscar el perfil en la tabla profiles por email
                    const { data: profileData, error: profileErr } = await supabase
                        .from('profiles')
                        .select('id, first_name')
                        .eq('email', email)
                        .single();

                    if (profileErr || !profileData) {
                        throw new Error("No se encontró ningún usuario cliente con ese correo. El barbero debe registrarse primero en la app.");
                    }

                    // 2. Cambiar su rol a 'barber'
                    const { error: roleErr } = await supabase
                        .from('profiles')
                        .update({ role: 'barber' })
                        .eq('id', profileData.id);

                    if (roleErr) {
                        throw new Error("Error al actualizar el rol del usuario.");
                    }

                    // 3. Crear el registro en 'barbers' vinculado a profile_id
                    const realNickname = inputAlias?.value || profileData.first_name || nickname;

                    const { error: insertErr } = await supabase.from('barbers').insert([{
                        profile_id: profileData.id,
                        nickname: realNickname,
                        specialty,
                        commission_rate,
                        base_quota_cuts,
                        is_active,
                        schedule
                    }]);

                    if (insertErr) {
                        // Podríamos tener una validación de clave única para no duplicarlo, atrapamos el error
                        if (insertErr.code === '23505') throw new Error("Este usuario ya está registrado como barbero.");
                        throw new Error("Error al crear el perfil de barbero: " + insertErr.message);
                    }

                    showNotif('¡Barbero vinculado exitosamente!');
                }

                setTimeout(() => {
                    closeModal();
                    loadBarbers();
                }, 1500);

            } catch (err: any) {
                console.error("Error procesando barbero:", err);
                showNotif(err.message || 'Error al procesar.', true);
            } finally {
                btnSubmit.innerHTML = originalText;
                btnSubmit.removeAttribute('disabled');
            }
        });
    </script>
</DashboardLayout>
