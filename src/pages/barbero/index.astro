---
import BarberoLayout from "../../layouts/BarberoLayout.astro";
import { ChevronLeft, ChevronRight, Users, Clock, CheckCircle, Wallet } from "lucide-react";
import ButtonCTA from "../../components/ui/ButtonCTA.astro";
---

<BarberoLayout title="Agenda | Barbería 99">
    <div class="w-full mx-auto space-y-6">
        <h1 class="hidden">Agenda de Citas</h1>

        <!-- Resumen de Métricas del Día -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-carbon/60 border border-white/5 p-4 rounded-sm backdrop-blur-sm">
                <span class="text-[10px] text-cement uppercase tracking-widest font-bold mb-1 block">Citas de Hoy</span>
                <span id="metricTotalApps" class="text-2xl font-display text-white border-l-2 border-amber pl-3 block">0</span>
            </div>
            <div class="bg-carbon/60 border border-white/5 p-4 rounded-sm backdrop-blur-sm">
                <span class="text-[10px] text-cement uppercase tracking-widest font-bold mb-1 block">Completadas</span>
                <span id="metricCompleted" class="text-2xl font-display text-white border-l-2 border-green-500 pl-3 block">0</span>
            </div>
            <div class="bg-carbon/60 border border-white/5 p-4 rounded-sm backdrop-blur-sm">
                <span class="text-[10px] text-cement uppercase tracking-widest font-bold mb-1 block">Ingresos (Est)</span>
                <span id="metricEarnings" class="text-2xl font-display text-white border-l-2 border-amber pl-3 block">$0</span>
            </div>
        </div>

        <!-- Toolbar de Navegación del Calendario -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div class="flex items-center gap-2">
                <button id="btnPrevDay" class="bg-carbon/60 hover:bg-white/10 text-cement hover:text-white border border-white/10 w-10 h-10 rounded-sm flex items-center justify-center transition-colors">
                    <ChevronLeft size={18} />
                </button>
                <div class="bg-carbon/60 border border-white/10 h-10 px-4 rounded-sm flex items-center justify-center min-w-[200px]">
                    <p id="currentDateDisplay" class="text-white text-sm font-medium">Cargando fecha...</p>
                </div>
                <button id="btnNextDay" class="bg-carbon/60 hover:bg-white/10 text-cement hover:text-white border border-white/10 w-10 h-10 rounded-sm flex items-center justify-center transition-colors">
                    <ChevronRight size={18} />
                </button>
                <button id="btnToday" class="bg-carbon/60 hover:bg-white/10 text-cement hover:text-white border border-white/10 h-10 px-3 ml-2 rounded-sm text-sm transition-colors hidden sm:block">
                    Hoy
                </button>
            </div>

            <div class="flex items-center gap-3 w-full sm:w-auto">
                <ButtonCTA class="!h-10 !px-4 !text-sm !w-auto !min-w-0 !font-semibold">
                    + Nueva Cita
                </ButtonCTA>
            </div>
        </div>

        <!-- Contenedor Principal (Lista de citas) -->
        <div class="bg-carbon/60 border border-white/5 rounded-sm backdrop-blur-sm p-4 overflow-hidden min-h-[50vh]">
            <div class="flex flex-col gap-3" id="appointmentsList">
                <div class="flex justify-center items-center h-40">
                    <p class="text-cement text-sm animate-pulse">Cargando citas...</p>
                </div>
            </div>
        </div>
    </div>
</BarberoLayout>

<script>
    import { supabase } from "../../lib/supabase";

    document.addEventListener('DOMContentLoaded', () => {
        let currentDate = new Date();

        const dateDisplay = document.getElementById('currentDateDisplay');
        const appointmentsList = document.getElementById('appointmentsList');
        const metricTotalApps = document.getElementById('metricTotalApps');
        const metricCompleted = document.getElementById('metricCompleted');
        const metricEarnings = document.getElementById('metricEarnings');
        const metricNewClients = document.getElementById('metricNewClients');

        const btnPrev = document.getElementById('btnPrevDay');
        const btnNext = document.getElementById('btnNextDay');
        const btnToday = document.getElementById('btnToday');

        const formatOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };

        function updateDateDisplay() {
            let texto = currentDate.toLocaleDateString('es-ES', formatOptions);
            dateDisplay.textContent = texto.charAt(0).toUpperCase() + texto.slice(1);
        }

        async function fetchAppointments() {
            appointmentsList.innerHTML = `<div class="flex justify-center items-center h-40"><p class="text-cement text-sm animate-pulse">Cargando citas...</p></div>`;

            // Formatear fecha para consulta (YYYY-MM-DD)
            const dateStr = `${currentDate.getFullYear()}-${String(currentDate.getMonth() + 1).padStart(2, '0')}-${String(currentDate.getDate()).padStart(2, '0')}`;

            try {
                // Import Supabase
                const { data, error } = await supabase
                    .from('appointments')
                    .select('*, profiles(first_name, phone, visits, points)')
                    .eq('appointment_date', dateStr)
                    .order('appointment_time', { ascending: true });

                if (error) throw error;

                renderAppointments(data || []);
            } catch (err) {
                console.error("Error al cargar citas:", err);
                appointmentsList.innerHTML = `<p class="text-red-400 text-center py-10">Error cargando agenda.</p>`;
            }
        }

        function renderAppointments(apps) {
            // Actualizar Métricas
            const completadas = apps.filter(a => a.status === 'completed' || a.status === 'completada').length;
            const pendientes = apps.filter(a => a.status === 'pending' || a.status === 'pendiente').length;
            const confirmadas = apps.filter(a => a.status === 'confirmed' || a.status === 'confirmada').length;
            
            // Asumimos un ingreso genérico por corte para la vista de ejemplo
            const ingresoEstimado = completadas * 20;

            if (metricTotalApps) metricTotalApps.textContent = apps.length.toString();
            if (metricCompleted) metricCompleted.textContent = completadas.toString();
            if (metricEarnings) metricEarnings.textContent = `$${ingresoEstimado}`;
            
            // Contar clientes nuevos (basado en visitas < 2)
            const nuevos = apps.filter(a => !a.profiles?.visits || a.profiles.visits < 2).length;
            if (metricNewClients) metricNewClients.textContent = nuevos.toString();

            if (apps.length === 0) {
                appointmentsList.innerHTML = `
                    <div class="flex flex-col items-center justify-center p-12 opacity-50 border border-white/5 border-dashed rounded-sm">
                        <p class="text-cement text-sm font-mono mt-4">[ No hay citas agendadas para este día ]</p>
                    </div>`;
                return;
            }

            let html = '';
            apps.forEach(app => {
                let timeParts = "00:00".split(':');
                if (app.appointment_time) {
                    timeParts = app.appointment_time.split(':');
                }
                
                // Parseo de info del cliente
                let clientName = 'Cliente Nuevo';
                let clientPhone = 'Sin número';
                let visitsCount = 0;
                
                if (app.profiles && app.profiles.first_name) {
                    clientName = app.profiles.first_name;
                    clientPhone = app.profiles.phone || 'Sin número';
                    visitsCount = app.profiles.visits || 0;
                }

                // Manejar notas / JSON para extraer servicios y nombre en caso de invitados
                let servicesText = app.notes || '';
                try {
                    if (app.notes && app.notes.trim().startsWith('{')) {
                        const parsed = JSON.parse(app.notes);
                        
                        // Si no tenemos nombre de perfil, intentamos usar el del JSON
                        if ((!app.profiles || !app.profiles.first_name) && parsed.clientName) {
                            clientName = parsed.clientName;
                            if (parsed.clientPhone) clientPhone = parsed.clientPhone;
                        }
                        
                        // Extraer nombres de servicios
                        if (parsed.services && Array.isArray(parsed.services)) {
                            servicesText = parsed.services.map(s => s.name).join(', ');
                        } else {
                            servicesText = "Corte/Servicio";
                        }
                    }
                } catch(e) {
                    // Si no es JSON valido, lo dejamos tal cual
                }

                const isCompleted = app.status === 'completed' || app.status === 'completada';
                const isCancelled = app.status === 'cancelled' || app.status === 'cancelada';
                const isConfirmed = app.status === 'confirmed' || app.status === 'confirmada';
                const isNoShow = app.status === 'no_show';

                let borderCol = 'border-amber/30';
                let statusBadge = '<span class="bg-amber/20 text-amber text-[10px] px-2 py-0.5 rounded-[1px] uppercase">Confirmada</span>';

                if(isCompleted) {
                    borderCol = 'border-green-500/30';
                    statusBadge = '<span class="bg-green-500/20 text-green-400 text-[10px] px-2 py-0.5 rounded-[1px] uppercase">Completada</span>';
                } else if (isCancelled) {
                    borderCol = 'border-red-500/30';
                    statusBadge = '<span class="bg-red-500/20 text-red-400 text-[10px] px-2 py-0.5 rounded-[1px] uppercase">Cancelada</span>';
                } else if (isConfirmed || app.status === 'pending' || app.status === 'pendiente') {
                    borderCol = 'border-amber/30';
                    statusBadge = '<span class="bg-amber/20 text-amber text-[10px] px-2 py-0.5 rounded-[1px] uppercase">Confirmada</span>';
                } else if (isNoShow) {
                    borderCol = 'border-purple-500/30';
                    statusBadge = '<span class="bg-purple-500/20 text-purple-400 text-[10px] px-2 py-0.5 rounded-[1px] uppercase">No Show</span>';
                }

                let nivelTexto = 'Bronce';
                if (visitsCount >= 15) nivelTexto = 'Oro';
                else if (visitsCount >= 8) nivelTexto = 'Plata';

                html += `
                    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between p-4 bg-white/5 hover:bg-white/10 border-l-2 ${borderCol} rounded-[2px] transition-colors gap-4">
                        <div class="flex items-center gap-4">
                            <div class="bg-carbon border border-white/10 w-20 h-14 flex items-center justify-center rounded-[2px] shrink-0">
                                <span class="text-white font-display text-lg tracking-wider">${timeParts[0]}:${timeParts[1]}</span>
                            </div>
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="text-white font-medium text-lg leading-none ${!(app.profiles && app.profiles.first_name) ? 'text-amber' : ''}">${clientName}</h3>
                                    <span class="text-[9px] px-1.5 py-0.5 rounded-sm bg-white/5 text-cement font-medium">${nivelTexto}</span>
                                    <span class="text-[9px] px-1.5 py-0.5 rounded-sm border border-white/5 text-cement font-mono uppercase">
                                        #${app.id.split('-')[0]}
                                    </span>
                                </div>
                                <p class="text-cement text-xs flex gap-2 items-center mt-1">
                                    <span>${clientPhone}</span>
                                    ${servicesText ? `<span class="opacity-50">|</span> <span>${servicesText}</span>` : ''}
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 w-full sm:w-auto justify-end mt-2 sm:mt-0">
                            ${statusBadge}
                            ${(app.status === 'pending' || app.status === 'pendiente' || app.status === 'confirmed' || app.status === 'confirmada') ? `
                            <button id="btn-complete-${app.id}" class="px-3 py-1.5 bg-green-500/10 border border-green-500/20 hover:border-green-500 hover:bg-green-500/20 text-green-500 text-xs rounded-[1px] transition-colors font-medium whitespace-nowrap cursor-pointer" onclick="window.completarCita('${app.id}', '${app.client_id || ''}', ${app.price})">
                                Marcar Completada
                            </button>
                            ` : ''}
                            <button class="px-3 py-1.5 bg-carbon border border-white/10 hover:border-amber text-cement hover:text-amber text-xs rounded-[1px] transition-colors whitespace-nowrap" onclick="window.location.href='/dashboard/agenda?id=${app.id}'">
                                Ver Detalle
                            </button>
                        </div>
                    </div>
                `;
            });

            appointmentsList.innerHTML = html;
        }

        // Navegación
        btnPrev.addEventListener('click', () => {
            currentDate.setDate(currentDate.getDate() - 1);
            updateDateDisplay();
            fetchAppointments();
        });

        btnNext.addEventListener('click', () => {
            currentDate.setDate(currentDate.getDate() + 1);
            updateDateDisplay();
            fetchAppointments();
        });

        btnToday.addEventListener('click', () => {
            currentDate = new Date();
            updateDateDisplay();
            fetchAppointments();
        });

        // Inicializar
        updateDateDisplay();
        fetchAppointments();

// Lógica para completar cita y asignar puntos
        window.completarCita = async (appointmentId, clientId, price) => {
            const btn = document.getElementById(`btn-complete-${appointmentId}`);
            if (!btn) return;

            // FASE 1: Confirmación In-line
            if (btn.dataset.confirming !== "true") {
                btn.dataset.confirming = "true";
                btn.innerText = "¿Confirmar Completada?";
                // Remover estilos base
                btn.classList.remove('bg-green-500/10', 'text-green-500', 'border-green-500/20', 'hover:border-green-500', 'hover:bg-green-500/20');
                // Añadir estilos solidos de alerta
                btn.classList.add('bg-green-500', 'text-white', 'border-green-500', 'hover:bg-green-600');
                
                // Reiniciar el botón si no se hace clic en 3 segundos
                setTimeout(() => {
                    if(btn && btn.dataset.confirming === "true") {
                        btn.dataset.confirming = "false";
                        btn.innerText = "Marcar Completada";
                        btn.classList.remove('bg-green-500', 'text-white', 'border-green-500', 'hover:bg-green-600');
                        btn.classList.add('bg-green-500/10', 'text-green-500', 'border-green-500/20', 'hover:border-green-500', 'hover:bg-green-500/20');
                    }
                }, 3000);
                return; // Pausamos ejecución hasta segundo clic
            }

            // FASE 2: Modificando estado y llamando BD
            const originalClasses = btn.className;
            btn.innerHTML = `<svg class="animate-spin h-4 w-4 mx-auto inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
            btn.disabled = true;

            try {
                // 1. Marcar la cita como completada (pagó y asistió)
                const { data: updatedApp, error: appError } = await supabase
                    .from('appointments')
                    .update({ status: 'completed' })
                    .eq('id', appointmentId)
                    .select(); // IMPORTANTE: Pedir la data de regreso para ver si RLS la bloqueó

                if (appError) throw appError;

                // Si no regresó data, significa que el RLS de Supabase nos bloqueó o la cita no existe
                if (!updatedApp || updatedApp.length === 0) {
                    throw new Error("SUPABASE_RLS_BLOCK: No tienes permisos en la base de datos (RLS) para actualizar esta cita. Revisa las políticas de RLS en 'appointments'.");
                }

                // 2. Si el cliente está registrado, sumar visita y puntos
                if (clientId && clientId !== 'null' && clientId !== 'undefined') {
                    // Obtener datos actuales del usuario
                    const { data: profile, error: profError } = await supabase
                        .from('profiles')
                        .select('points, visits')
                        .eq('id', clientId)
                        .single();

                    if (!profError && profile) {
                        // 1 peso = 1 punto
                        const priceNum = Number(price) || 0;
                        const newPoints = (profile.points || 0) + Math.floor(priceNum);
                        const newVisits = (profile.visits || 0) + 1;

                        await supabase
                            .from('profiles')
                            .update({ points: newPoints, visits: newVisits })
                            .eq('id', clientId);
                    }
                }

                // Mostrar éxito in-line (sin alert ruidoso)
                btn.innerHTML = `¡Guardado!`;
                
                setTimeout(() => {
                    fetchAppointments(); // refrescar
                }, 1200);

            } catch (error) {
                console.error("Error definitivo al completar:", error);
                
                // Mostrar error in-line
                btn.className = "px-3 py-1.5 bg-red-500/10 border border-red-500/20 text-red-500 text-xs rounded-[1px] font-medium whitespace-nowrap";
                btn.innerText = "Error de Permisos (Reintentar)";
                btn.dataset.confirming = "false";
                btn.disabled = false;

                if (error.message && error.message.includes('RLS')) {
                    alert('Acceso Denegado: La base de datos (Supabase) bloqueó el cambio por políticas RLS. Necesitas desactivarlas o iniciar sesión.');
                } else {
                    alert('Hubo un error al intentar guardar: ' + error.message);
                }
                
                setTimeout(() => {
                    btn.className = originalClasses;
                    btn.innerText = "Marcar Completada";
                }, 3000);
            }
        };

    });
</script>
