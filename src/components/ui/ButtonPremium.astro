---
/**
 * ButtonPremium - Navigation-style button with a subtle border and shimmer on hover.
 * Style: Transparent dark glass with border. Variant "gold" for Club 99 accents.
 *
 * Props:
 *   href    (string)  - The link destination.
 *   gold    (boolean) - If true, uses the amber/gold color scheme (for Club 99).
 *   class   (string)  - Optional extra Tailwind classes.
 */
interface Props {
    href: string;
    gold?: boolean;
    class?: string;
}

const { href, gold = false, class: className = "" } = Astro.props;
---

<a
    href={href}
    class={`btn-premium ${gold ? "btn-premium-gold" : ""} flex items-center justify-center gap-2 ${className}`}
>
    <slot />
</a>

<style>
    .btn-premium {
        position: relative;
        padding: 0.5em 1.5em;
        background: transparent;
        color: rgba(255, 255, 255, 0.8);
        font-size: 15px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.4s ease;
        text-decoration: none;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-premium::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.2),
            transparent
        );
        transition: left 0.5s ease;
    }

    .btn-premium:hover {
        border-color: rgba(255, 255, 255, 0.5);
        color: white;
        background: rgba(255, 255, 255, 0.05);
        box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
    }

    .btn-premium:hover::before {
        left: 100%;
    }

    /* Gold Variant — for Club 99 */
    .btn-premium-gold {
        color: #f7e479;
        border-color: rgba(247, 228, 121, 0.2);
    }

    .btn-premium-gold:hover {
        border-color: rgba(247, 228, 121, 0.8);
        color: #fff;
        background: rgba(247, 228, 121, 0.1);
        box-shadow: 0 0 15px rgba(247, 228, 121, 0.3);
    }

    .btn-premium-gold::before {
        background: linear-gradient(
            90deg,
            transparent,
            rgba(247, 228, 121, 0.4),
            transparent
        );
    }
</style>
