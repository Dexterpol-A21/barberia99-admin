<div
    class="flex items-center gap-3 md:gap-4 select-none group relative z-10 transition-transform duration-300 origin-left"
>
    <!-- Left Side: Barbería Text -->
    <div class="flex flex-col items-end">
        <span
            class="font-display font-bold text-base md:text-xl tracking-[0.2em] text-[#F5F5F5] uppercase mb-0.5 transition-colors"
        >
            Barbería
        </span>
        <span
            class="font-body text-[0.5rem] md:text-[0.6rem] tracking-[0.25em] text-cement uppercase"
        >
            Est. 2026
        </span>
    </div>

    <!-- Divider -->
    <div class="h-8 md:h-10 w-[1px] bg-white/20"></div>

    <!-- Right Side: 99 + Mustache -->
    <div class="flex flex-col items-center justify-center translate-y-2">
        <span
            class="font-display font-bold text-2xl md:text-3xl leading-none text-[#F5F5F5] select-none transition-colors"
        >
            99
        </span>
        <!-- 
         Scaled proportions:
         Mobile (text-2xl/1.5rem): Width ~2.1rem, Margin ~-0.7rem
         Desktop (text-3xl/1.875rem): Width ~2.625rem, Margin ~-0.86rem
      -->
        <div
            class="w-[2.1rem] md:w-[2.65rem] text-white -mt-[0.7rem] md:-mt-[0.9rem] opacity-90 transition-colors"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-full h-full"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                <path
                    d="M12 11c1.5 -2 3 -2 4 -1c2 2 4 1 5 -1c0 0 -2 5 -5 1c-1 -1.3 -3 -0.5 -4 1c-1 -1.5 -3 -2.3 -4 -1c-3 4 -5 -1 -5 -1c1 2 3 3 5 1c1 -1 2.5 -1 4 1"
                ></path>
            </svg>
        </div>
    </div>
</div>
