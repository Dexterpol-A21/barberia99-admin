---
import Layout from "./Layout.astro";
import { Users, Scissors, Calendar, LayoutDashboard, ClipboardList, DollarSign, LogOut } from "lucide-react";
import Logo from "../components/Logo.astro";

const { title = "Dashboard Dueño | Barbería 99" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Layout title={title}>
    <div class="min-h-screen bg-[#050301] text-bone flex">
        <!-- Sidebar -->
        <aside class="w-64 bg-[#0a0806] border-r border-white/5 flex flex-col hidden md:flex shrink-0">
            <div class="h-20 flex items-center justify-center border-b border-white/5 shrink-0 relative">
                <div class="scale-75 origin-center">
                    <Logo />
                </div>
                <span class="absolute bottom-2 right-4 text-[9px] font-body text-amber tracking-[0.3em] font-bold uppercase bg-amber/10 px-2 py-0.5 rounded-sm">Admin</span>
            </div>

            <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
                <div class="mb-2 px-4 pt-2">
                    <p class="text-[10px] text-cement/50 uppercase tracking-widest font-bold">Operación</p>
                </div>

                <a href="/dashboard" class={`flex items-center gap-3 px-4 py-3 rounded-sm transition-colors group ${currentPath === '/dashboard' || currentPath === '/dashboard/' ? 'bg-white/5 text-amber border border-white/10' : 'text-cement hover:text-white hover:bg-white/5'}`}>
                    <LayoutDashboard size={18} class={currentPath === '/dashboard' || currentPath === '/dashboard/' ? '' : 'group-hover:text-amber transition-colors'} />
                    <span class="text-sm font-medium">Resumen General</span>
                </a>

                <a href="/dashboard/agenda" class={`flex items-center gap-3 px-4 py-3 rounded-sm transition-colors group ${currentPath.includes('/dashboard/agenda') ? 'bg-white/5 text-amber border border-white/10' : 'text-cement hover:text-white hover:bg-white/5'}`}>
                    <Calendar size={18} class={currentPath.includes('/dashboard/agenda') ? '' : 'group-hover:text-amber transition-colors'} />
                    <span class="text-sm font-medium">Agenda</span>
                </a>

                <a href="/dashboard/caja" class={`flex items-center gap-3 px-4 py-3 rounded-sm transition-colors group ${currentPath.includes('/dashboard/caja') ? 'bg-white/5 text-amber border border-white/10' : 'text-cement hover:text-white hover:bg-white/5'}`}>
                    <DollarSign size={18} class={currentPath.includes('/dashboard/caja') ? '' : 'group-hover:text-amber transition-colors'} />
                    <span class="text-sm font-medium">Corte de Caja</span>
                </a>

                <div class="mt-6 mb-2 px-4 pt-4 border-t border-white/5">
                    <p class="text-[10px] text-cement/50 uppercase tracking-widest font-bold">Gestión</p>
                </div>

                <a href="/dashboard/menu" class={`flex items-center gap-3 px-4 py-3 rounded-sm transition-colors group ${currentPath.includes('/dashboard/menu') ? 'bg-white/5 text-amber border border-white/10' : 'text-cement hover:text-white hover:bg-white/5'}`}>
                    <ClipboardList size={18} class={currentPath.includes('/dashboard/menu') ? '' : 'group-hover:text-amber transition-colors'} />
                    <span class="text-sm font-medium">Menú</span>
                </a>

                <a href="/dashboard/barberos" class={`flex items-center gap-3 px-4 py-3 rounded-sm transition-colors group ${currentPath.includes('/dashboard/barberos') ? 'bg-white/5 text-amber border border-white/10' : 'text-cement hover:text-white hover:bg-white/5'}`}>
                    <Scissors size={18} class={currentPath.includes('/dashboard/barberos') ? '' : 'group-hover:text-amber transition-colors'} />
                    <span class="text-sm font-medium">Barberos</span>
                </a>

                <a href="/dashboard/clientes" class={`flex items-center gap-3 px-4 py-3 rounded-sm transition-colors group ${currentPath.includes('/dashboard/clientes') ? 'bg-white/5 text-amber border border-white/10' : 'text-cement hover:text-white hover:bg-white/5'}`}>
                    <Users size={18} class={currentPath.includes('/dashboard/clientes') ? '' : 'group-hover:text-amber transition-colors'} />
                    <span class="text-sm font-medium">Clientes</span>
                </a>
            </nav>

            <div class="p-4 border-t border-white/5">
                <button id="logout-btn" class="w-full flex items-center gap-3 text-[#cc0000] hover:bg-[#cc0000]/10 px-4 py-3 rounded-sm transition-colors cursor-pointer text-left">
                    <LogOut size={18} />
                    <span class="text-sm font-medium tracking-wide">Cerrar Sesión</span>
                </button>
            </div>
        </aside>

        <!-- Main Content (Manejado por slot para inyectar cada pagina) -->
        <main class="flex-1 flex flex-col max-h-screen overflow-hidden">
            <!-- Topbar -->
            <header class="h-20 border-b border-white/5 bg-[#0a0806]/80 backdrop-blur-md flex items-center justify-between px-6 shrink-0 z-10">
                <div class="md:hidden">
                    <span class="text-xl font-display font-bold text-white">99<span class="text-amber">.</span></span>
                </div>
                <div class="hidden md:block">
                    <h2 class="text-lg font-medium tracking-wide text-white" id="header-title">Dashboard</h2>
                    <p class="text-xs text-cement">Viendo información en tiempo real</p>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="text-right hidden sm:block">
                        <p class="text-[10px] text-cement uppercase tracking-widest font-bold">Caja Abierta</p>
                        <p class="text-sm text-green-400 font-medium">Sucursal Coacalco</p>
                    </div>
                    <div class="w-10 h-10 rounded-sm bg-amber text-black flex items-center justify-center font-bold text-lg">
                        D
                    </div>
                </div>
            </header>

            <!-- Dashboard Content Slot -->
            <div class="flex-1 overflow-y-auto bg-[#050301] relative" data-lenis-prevent>
                <div class="relative z-10 p-6 md:p-8">
                    <slot />
                </div>
            </div>
        </main>
    </div>

    <!-- Script de Cerrar Sesion Global -->
    <script>
        import { supabase } from "../lib/supabase";

        const logoutBtn = document.getElementById("logout-btn");
        logoutBtn?.addEventListener("click", async () => {
            const { error } = await supabase.auth.signOut();
            if (!error) {
                window.location.href = "/";
            }
        });

        // Autocompleta el Titulo del Topbar basandose en el h1 de la pagina o el title del layout
        const titleH1 = document.querySelector('h1')?.innerText;
        const headerTitle = document.getElementById('header-title');
        if(titleH1 && headerTitle) {
            headerTitle.innerText = titleH1;
        }

        // Apply RBAC
        const { data: { user } } = await supabase.auth.getUser();
        if (user) {
            const name = user.user_metadata?.nickname || 'Usuario';
            const nameEl = document.getElementById('topbar-user-name');
            if (nameEl) nameEl.textContent = name;        }
    </script>
</Layout>